{
  "$schema": "https://github.com/MountainUnicorn/add/config.schema.json",
  "version": "0.5.0",
  "project": {
    "name": "drugs-quiz",
    "description": "A React frontend app that quizzes pharmacy professionals on drug names, brand/generic pairs, and pharmacological classes using the drug-gate API",
    "created": "2026-03-15",
    "author": "Caleb Dunn"
  },
  "maturity": {
    "level": "beta",
    "promoted_from": "alpha",
    "promoted_date": "2026-03-20",
    "next_promotion_criteria": "Feature specs for all user-facing features, test coverage above 50%, PR workflow with code review, at least 2 deployment environments active, TDD evidence"
  },
  "architecture": {
    "languages": [
      {
        "name": "TypeScript",
        "version": "5.x",
        "role": "frontend"
      }
    ],
    "backend": {
      "framework": "Hono",
      "version": "latest",
      "runtime": "node"
    },
    "frontend": {
      "framework": "React",
      "version": "19",
      "bundler": "vite"
    },
    "database": {
      "type": "postgresql",
      "version": "16"
    },
    "containerized": true,
    "container_strategy": "docker-compose",
    "suggested_by_claude": true
  },
  "infrastructure": {
    "git_host": "github",
    "git_remote": "git@github.com:finish06/drugs-quiz.git",
    "cloud_provider": "aws",
    "cloud_services": ["EC2"],
    "cicd": {
      "platform": "github-actions",
      "scaffolded_by_add": true,
      "pipeline_file": ".github/workflows/ci.yml"
    },
    "infrastructure_as_code": "none"
  },
  "environments": {
    "tier": 3,
    "local": {
      "run": "npm run dev",
      "test": "npx vitest run",
      "e2e": "npx playwright test",
      "url": "http://localhost:5173"
    },
    "dev": {
      "deploy_trigger": "push to dev branch",
      "url": "TBD",
      "verify": ["unit_tests", "integration_tests"]
    },
    "staging": {
      "deploy_trigger": "push to staging branch",
      "url": "https://drug-quiz.staging.calebdunn.tech",
      "verify": ["e2e_tests", "performance_tests"]
    },
    "production": {
      "deploy_trigger": "merge to main",
      "verify": ["smoke_tests"],
      "url": "https://rxdrill.com",
      "requires_approval": true
    }
  },
  "quality": {
    "mode": "strict",
    "coverage_threshold": 90,
    "type_check_blocking": true,
    "e2e_required": true,
    "screenshot_protocol": true,
    "lint": {
      "frontend": "npx eslint . --ext .ts,.tsx"
    },
    "typecheck": {
      "frontend": "npx tsc --noEmit"
    },
    "test": {
      "unit": "npx vitest run",
      "integration": "npx vitest run --project integration",
      "e2e": "npx playwright test"
    }
  },
  "collaboration": {
    "autonomy_level": "balanced",
    "team_size": "solo",
    "commit_review_gate": false,
    "pr_review_gate": true,
    "deploy_approval_required": true
  },
  "source_control": {
    "branching": "feature-branches",
    "default_branch": "main",
    "commit_convention": "conventional",
    "pr_template": true,
    "protected_branches": ["main"]
  },
  "branding": {
    "accentColor": "#3b82f6",
    "presetName": null,
    "palette": {
      "accent": "#3b82f6",
      "accentLight": "#6ba3f8",
      "accentDark": "#1d5bbf",
      "accentMuted": "#93b8e8",
      "accentGlow": "rgba(59, 130, 246, 0.4)",
      "gradientStart": "#3b82f6",
      "gradientMid": "#6ba3f8",
      "gradientEnd": "#a8b5fa",
      "success": "#22c55e",
      "warning": "#eab308",
      "info": "#0ea5e9"
    },
    "fonts": {
      "heading": "system-ui, -apple-system, sans-serif",
      "body": "system-ui, -apple-system, sans-serif",
      "code": "ui-monospace, SFMono-Regular, monospace"
    },
    "tone": "Professional yet approachable — make complex systems feel simple, useful, and intuitive",
    "logoPath": "images/logo-light.png",
    "logoDarkPath": "images/logo-dark.png",
    "styleGuideSource": "https://www.calebdunn.tech"
  },
  "imageGeneration": {
    "enabled": true,
    "tool": "mcp__imgGen__generate_image",
    "plugin": "imgGen",
    "nudged": true,
    "lastDetected": "2026-03-22"
  },
  "changelog": {
    "lastProcessedCommit": "cb28f8fd3b79aec1624d3cad2a26fa6bdd8ba508",
    "lastVersionTag": "v0.5.13"
  },
  "planning": {
    "current_milestone": "M6-Compete-Go-Native",
    "current_cycle": "cycle-11",
    "wip_limit": 2,
    "parallel_agents": 2,
    "cycle_history": []
  }
}
