# drug-gate API (used by the reverse proxy, NOT the frontend)
# Local: http://localhost:8085
# Staging/Prod: https://drug-gate.calebdunn.tech
DRUG_GATE_URL=http://localhost:8085
DRUG_GATE_API_KEY=pk_your_key_here

# Database (Postgres)
DATABASE_URL=postgres://drugs_quiz:localdev@localhost:5432/drugs_quiz
POSTGRES_PASSWORD=localdev

# Application URL (used for OAuth redirects, share pages, SEO)
# BFF reads APP_URL at runtime; frontend reads VITE_APP_URL at build time
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173

# Google OAuth (M5)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
JWT_SECRET=your_jwt_secret_min_32_chars_long
